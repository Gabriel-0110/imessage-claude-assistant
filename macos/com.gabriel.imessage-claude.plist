<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template plist. Do not copy directly into ~/Library/LaunchAgents.
  Run scripts/install-imessage-launch-agent.sh to substitute:
    __REPO_ROOT__ -> absolute path to this repository
    __HOME__      -> $HOME
    __LABEL__     -> LaunchAgent label (defaults to com.gabriel.imessage-claude)

  This plist runs the bun iMessage bridge server directly.
  The menubar app (macos/iMessageAssistant/) provides the UI.
-->
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>__LABEL__</string>

    <key>ProgramArguments</key>
    <array>
      <string>__HOME__/.bun/bin/bun</string>
      <string>run</string>
      <string>--cwd</string>
      <string>__REPO_ROOT__/plugins/imessage</string>
      <string>start</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>__REPO_ROOT__</string>

    <key>StandardOutPath</key>
    <string>__REPO_ROOT__/state/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>__REPO_ROOT__/state/launchd.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>__HOME__</string>
      <key>PATH</key>
      <string>__HOME__/.bun/bin:__HOME__/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
      <key>IMESSAGE_BRIDGE_ENABLED</key>
      <string>1</string>
    </dict>
  </dict>
</plist>
